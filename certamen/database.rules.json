{
  "rules": {
    "rooms": {
      "$code": {
        ".read": true,
        ".write": true
      }
    },
    "identities": {
      "$klas": {
        ".read": "auth != null && (!root.child('klascodes/'+$klas+'/ownerUid').exists() || auth.uid === root.child('klascodes/'+$klas+'/ownerUid').val())",
        "$lid": {
          ".read": true,
          ".write": "!newData.child('admin').exists() || (data.child('admin').exists() && data.child('admin').val() === newData.child('admin').val())",
          ".validate": "newData.hasChildren(['name'])",
          "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 60" },
          "coins": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "xp": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "level": { ".validate": "newData.isNumber() && newData.val() >= 1" },
          "battles": { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "admin": {
            ".write": "auth != null",
            ".validate": "newData.isBoolean()"
          },
          "googleUid": {
            ".write": "auth != null && auth.uid === newData.val() && (!data.exists() || data.val() === auth.uid)",
            ".validate": "newData.isString() && newData.val() === auth.uid"
          }
        }
      }
    },
    "klascodes": {
      ".read": true,
      "$code": {
        ".write": "auth != null && (!data.exists() || !data.child('ownerUid').exists() || auth.uid === data.child('ownerUid').val())",
        ".validate": "newData.hasChildren(['created','ownerUid']) && newData.child('created').isNumber()",
        "ownerUid": { ".validate": "newData.isString() && newData.val() === auth.uid" }
      }
    },
    "teachers": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "googleLinks": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['klas','lid'])",
        "klas": { ".validate": "newData.isString() && newData.val().length > 0" },
        "lid": { ".validate": "newData.isString() && newData.val().length > 0" },
        "linkedAt": { ".validate": "newData.isNumber()" }
      }
    },
    "totalwar": {
      ".read": true,
      ".write": "auth != null",
      "provinces": {
        "$id": {
          ".write": true,
          ".validate": "newData.hasChildren(['owner','militiaPoints','wallPoints','towerPoints']) && newData.child('militiaPoints').isNumber() && newData.child('wallPoints').isNumber() && newData.child('towerPoints').isNumber()"
        }
      },
      "civs": {
        "$id": { ".write": true }
      },
      "klasSize": {
        "$klas": {
          ".read": true,
          "students": {
            "$lid": {
              ".write": true,
              ".validate": "newData.isBoolean()"
            }
          }
        }
      },
      "stats": {
        "topBuilder": {
          ".write": true,
          ".validate": "newData.hasChildren(['name','points']) && newData.child('points').isNumber()"
        }
      }
    },
    "usedKlascodes": {
      ".read": "auth != null",
      "_seeded": { ".write": "auth != null", ".validate": "newData.isBoolean()" },
      "$klas": { ".write": true, ".validate": "newData.isNumber() && newData.val() >= 0" }
    },
    "classAnalytics": {
      "$klas": {
        ".read": true,
        "$month": {
          ".validate": "$month.matches(/^[0-9]{4}-[0-9]{2}$/)",
          "$wordkey": {
            ".write": true,
            ".validate": "newData.hasChildren(['p','c']) && newData.child('c').isNumber() && newData.child('c').val() >= 0",
            "p": { ".validate": "newData.isString() && newData.val().length <= 80" },
            "a": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "c": { ".validate": "newData.isNumber() && newData.val() >= 0" }
          }
        }
      }
    }
  }
}
